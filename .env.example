# Optional environment variables. Copy to `.env` (NOT committed) and fill in.
# These are read at process start by the Prefect flow and any --profile-aware script.

# ── Profile selection ────────────────────────────────────────────────────────
# One of: cpu | gpu | cloud  (or unset to autodetect)
# CFM_PROFILE=gpu

# ── MLflow tracking ──────────────────────────────────────────────────────────
# Local file store is the default. Set this to push runs to a remote server.
# Example DagsHub: https://dagshub.com/<user>/<repo>.mlflow
# MLFLOW_TRACKING_URI=
# MLFLOW_TRACKING_USERNAME=
# MLFLOW_TRACKING_PASSWORD=

# ── Cloud profile (Colab / Kaggle) ───────────────────────────────────────────
# Used by configs/profiles/cloud.yaml; takes precedence over MLFLOW_TRACKING_URI.
# DAGSHUB_MLFLOW_URI=

# ── DVC remote (optional, for raw data + large model artifacts) ──────────────
# DVC_REMOTE_URL=
